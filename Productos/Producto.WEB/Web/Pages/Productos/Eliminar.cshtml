@page
@model Web.Pages.Productos.EliminarModel
@{
}

<h1>Eliminar Producto</h1>

<header class="subhead">
    <div class="container">
        <div class="masthead-subheading">SC-701: Programación Web Avanzada</div>
        <div class="masthead-heading text-uppercase">Practica en clase 7 Productos</div>
    </div>
</header>
<section class="page-section bg-light" id="principal">
    <div class="container">
        <div class="container">
            <div class="text-center">
                <h2 class="section-heading text-uppercase">Eliminar Producto</h2>
                <h3 class="section-subheading text-muted">Esta sección es para eliminar producto.</h3>
            </div>

            <div class="col-xl-5 col-lg-6 col-md-8 col-sm-10 mx-auto ">
                <form method="post">
                <h5 class="card-title">@Html.DisplayFor(m => m.producto.Categoria)</h5>
                <p class="card-text">
                    <div>
                        <b>@Html.DisplayNameFor(subCategoria => subCategoria.producto.Nombre): </b>
                        @Html.DisplayFor(subCategoria => subCategoria.producto.Nombre)
                    </div>
                    <div>
                        <b>@Html.DisplayNameFor(subCategoria => subCategoria.producto.Descripcion): </b>
                        @Html.DisplayFor(subCategoria => subCategoria.producto.Descripcion)
                    </div>
                    <div>
                        <b>@Html.DisplayNameFor(subCategoria => subCategoria.producto.Precio):</b>
                        @Html.DisplayFor(subCategoria => subCategoria.producto.Precio)
                    </div>
                    <div>
                        <b>@Html.DisplayNameFor(subCategoria => subCategoria.producto.Stock):</b>
                        @Html.DisplayFor(subCategoria => subCategoria.producto.Stock)
                    </div>
                </p>
                <p class="card-text"><small class="text-muted">@Html.DisplayFor(subCategoria => subCategoria.producto.CodigoBarras) </small></p>
                    <div class="mt-3">
                        <a class="btn btn-secondary" asp-page="./Index">Cancelar</a>
                        <button type="submit" class="btn btn-danger">Eliminar</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
          
</section>