@page
@model Web.Pages.Productos.IndexModel
@{
}

<header class="subhead">
    <div class="container">
        <div class="masthead-subheading">SC-701: Programación Web Avanzada</div>
        <div class="masthead-heading text-uppercase">Listado de Productos</div>
    </div>
</header>
<div class="container">
	<div class="text-center mb-4">
		<div class="text-center mb-4">
			<a type="button" class="btn btn-group-lg btn-success btn-lg" asp-page="./Agregar"><i class="bi bi-plus-square"></i> Agregar</a>
		</div>
        <div class="row">
            @if (Model.productos != null)
                @foreach (var producto in Model.productos)
                {
                    <div class="col-md-4 mb-4">
                        <div class="card">
                            <div class="card-body">
                                <h5 class="card-title"> <i class="bi bi-car-front-fill"></i>@Html.DisplayFor(modelItem => producto.Categoria)@Html.DisplayFor(modelItem => producto.Nombre)</h5>
                                <h6 class="card-subtitle mb-2 text-muted">ID: @Html.DisplayFor(modelItem => producto.Id)</h6>
                                <p class="card-text"><strong>Precio:</strong> @Html.DisplayFor(modelItem => producto.Precio)</p>
                                <a type="button" class="btn btn-primary" asp-page="./Detalle" asp-route-id="@producto.Id"><i class="bi bi-info-square"></i> Detalle</a>
                                <a type="button" class="btn btn-warning" asp-page="./Editar" asp-route-id="@producto.Id"><i class="bi bi-pencil-square"></i> Editar</a>
                                <a type="button" class="btn btn-danger" asp-page="./Eliminar" asp-route-id="@producto.Id"><i class="bi bi-trash3-fill"></i> Eliminar</a>
                            </div>
                        </div>
                    </div>
                }
            else
            {
                <div class="alert alert-warning" role="alert">
                    No hay productos disponibles.
                </div>
            }
        </div>
